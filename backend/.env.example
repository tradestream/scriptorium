# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///data/config/scriptorium.db

# File Paths
LIBRARY_PATH=data/library
INGEST_PATH=data/ingest
CONFIG_PATH=data/config
COVERS_PATH=data/covers

# Security
SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# API
API_VERSION=v1

# ── Text-to-speech (optional) ────────────────────────────────────────
# Each backend is independent. Leave blank to disable that one — the
# reader's TTS panel only shows toggles for backends that are wired up.
# See docs/tts-setup.md for setup details and adding more local Macs.

# Local TTS — one or more LAN-reachable mlx_audio.server instances
# (Apple Silicon Macs running Qwen3-TTS). Comma-separated for failover:
# preferred Mac first, always-on Mac second.
# LOCAL_TTS_URL=http://m3-pro.local:9000,http://mac-mini.local:9000
# LOCAL_TTS_MODEL=mlx-community/Qwen3-TTS-12Hz-1.7B-Base-8bit
# LOCAL_TTS_VOICE=Cherry

# Qwen via Alibaba DashScope (cloud)
# DASHSCOPE_API_KEY=sk-...
# QWEN_TTS_MODEL=qwen3-tts-flash
# QWEN_TTS_VOICE=Cherry

# ElevenLabs (cloud, paid per character)
# ELEVENLABS_API_KEY=sk_...
# ELEVENLABS_MODEL=eleven_multilingual_v2
# ELEVENLABS_VOICE=21m00Tcm4TlvDq8ikWAM
