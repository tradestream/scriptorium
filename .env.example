# Scriptorium Configuration
SECRET_KEY=change-this-to-a-random-string
DATABASE_URL=sqlite+aiosqlite:////data/config/scriptorium.db
LIBRARY_PATH=/data/library
INGEST_PATH=/data/ingest
CONFIG_PATH=/data/config
COVERS_PATH=/data/covers

# Optional: SMTP for Send-to-Kindle / email delivery
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=app-password
# SMTP_FROM=scriptorium@yourdomain.com
# SMTP_TLS=true

# OIDC / SSO authentication (optional — leave OIDC_ENABLED=false to disable)
# OIDC_ENABLED=false
# OIDC_DISCOVERY_URL=https://accounts.google.com   # or your IdP discovery URL
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URI=https://your-scriptorium-host/api/v1/auth/oidc/callback
# OIDC_SCOPES=openid email profile

# Auto-ingest preferences
# INGEST_AUTO_CONVERT=false          # Set true to convert on ingest
# INGEST_TARGET_FORMAT=epub          # epub, mobi, azw3, pdf
# INGEST_AUTO_ENRICH=false           # Set true to enrich metadata on ingest
# INGEST_DEFAULT_PROVIDER=           # hardcover, google_books, open_library, calibre

# Metadata enrichment providers
# Google Books — optional key raises rate limits
# GOOGLE_BOOKS_API_KEY=

# Hardcover — https://hardcover.app/account/api
# HARDCOVER_API_KEY=

# ComicVine — https://comicvine.gamespot.com/api/ (comics/graphic novels)
# COMICVINE_API_KEY=

# ISBNDB — https://isbndb.com/apidocs/v2 (ISBN-focused database)
# ISBNDB_API_KEY=

# LLM Analysis (choose one provider)
# LLM_PROVIDER=anthropic  # "anthropic", "ollama", "openai"

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250514

# Ollama (local, fully offline)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# OpenAI-compatible (works with OpenAI, Together, Groq, etc.)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
